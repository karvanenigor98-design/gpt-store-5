# Скопируй в Vercel → Settings → Environment Variables (Production + Preview)
# Минимум для лендинга GPT STORE на первом деплое

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# После первого деплоя подставь реальный URL проекта:
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
NEXT_PUBLIC_GPT_STORE_URL=https://your-project.vercel.app

# Опционально
# NEXT_PUBLIC_YM_ID=12345678
