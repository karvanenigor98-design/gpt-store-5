# Vercel → subs-store project (отдельный публичный лендинг Subs Store)
# Production + Preview + Development

# Обязательно: отдельный деплой = только Subs (главная → /spotify)
STORE_PROFILE=subs-store
NEXT_PUBLIC_STORE_PROFILE=subs-store

# Subs Supabase (клиенты, заказы, чат)
SUBS_SUPABASE_URL=https://xxxx.supabase.co
SUBS_SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUBS_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUBS_SUPABASE_ANON_KEY=

# GPT Supabase (админка / оператор в общей панели)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# После первого деплоя:
NEXT_PUBLIC_APP_URL=https://subs-store.vercel.app
NEXT_PUBLIC_SUBS_STORE_URL=https://subs-store.vercel.app
NEXT_PUBLIC_GPT_STORE_URL=https://gpt-store-5.vercel.app

# SUBS_NOTIFICATIONS_INBOX_USER_ID=...
