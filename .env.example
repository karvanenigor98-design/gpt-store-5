# ============================================================
# GPT STORE — переменные окружения
# Скопируй в .env.local и заполни реальными значениями
# ============================================================

# SUPABASE (supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ------------------------------------------------------------
# Subs Store — отдельный проект Supabase (только сервер в GPT STORE)
# Нужно для админки GPT STORE при выборе site=subs-store (дашборд и далее — API).
# URL и service role из Supabase Subs Store → Settings → API
# ------------------------------------------------------------
SUBS_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Секрет с полными правами: legacy «service_role» (eyJ...) из Settings → API
# или новый «Secret API key» (sb_secret_...) — в зависимости от версии @supabase/supabase-js
SUBS_SUPABASE_SERVICE_ROLE_KEY=
# Куда писать уведомления о новом сообщении в чате Subs (UUID пользователя в Subs Auth / spotify).
# Если пусто — берётся первый пользователь Subs Auth с email = ADMIN_EMAIL.
# SUBS_NOTIFICATIONS_INBOX_USER_ID=
# Автоподбор UUID в .env.local: npm run env:subs-inbox
# (нужен сетевой доступ к SUBS_SUPABASE_URL и хотя бы один пользователь в Subs Auth)

# Опционально, если нужен явный дубль URL под другим именем:
# SUBS_NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase Storage: публичный bucket для вложений в чат (или оставьте по умолчанию chat-attachments)
# В Dashboard → Storage → New bucket → public
SUPABASE_CHAT_ATTACHMENTS_BUCKET=chat-attachments
# Realtime: Database → Publications → supabase_realtime — включить таблицы chat_messages, chat_sessions, orders

# APP
NEXT_PUBLIC_APP_URL=https://gpt-store-5.vercel.app
# Ссылки в email (если пусто — используется NEXT_PUBLIC_APP_URL)
NEXT_PUBLIC_GPT_STORE_URL=https://gpt-store-5.vercel.app
NEXT_PUBLIC_SUBS_STORE_URL=https://gpt-store-5.vercel.app/spotify

# Почта админа для операционных уведомлений (приоритетнее SUPPORT_NOTIFICATION_EMAIL и ADMIN_EMAILS)
ADMIN_EMAIL=you@example.com
# Альтернатива: одна почта поддержки
# SUPPORT_NOTIFICATION_EMAIL=
# Или список через запятую
# ADMIN_EMAILS=a@example.com,b@example.com

# RESEND (resend.com) — альтернатива SMTP для transactional email
RESEND_API_KEY=
# От кого (домен должен быть верифицирован в Resend)
RESEND_FROM_EMAIL=GPT STORE <onboarding@resend.dev>

# SMTP — основной провайдер transactional email (EMAIL_PROVIDER=smtp)
EMAIL_PROVIDER=smtp
EMAIL_NOTIFICATIONS_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=GPT STORE
OPERATOR_EMAIL=
# OPERATOR_EMAILS=op1@example.com,op2@example.com
# Для сброса пароля можно использовать отдельный sender (если не задан — берётся RESEND_FROM_EMAIL)
RESET_PASSWORD_FROM_EMAIL=

# DEEPSEEK AI (platform.deepseek.com)
# БЕЗ ЭТОГО КЛЮЧА AI ЧАТ НЕ РАБОТАЕТ
DEEPSEEK_API_KEY=sk-...
# Необязательно, если нужен кастомный endpoint
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# OPENROUTER AI (openrouter.ai) — можно использовать бесплатные модели (:free)
# Приоритетнее DeepSeek в /api/chat
OPENROUTER_API_KEY=
# Необязательно: своя бесплатная/платная модель, пример:
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# TELEGRAM — уведомления оператору/админу (клиентам бот не шлёт)
# TELEGRAM_BOT_TOKEN — токен от @BotFather
# TELEGRAM_ADMIN_CHAT_ID — id чата или пользователя, куда слать алерты
TELEGRAM_BOT_TOKEN=1234567890:AABBcc...
TELEGRAM_BOT_USERNAME=GptStoreBot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=GptStoreBot
TELEGRAM_ADMIN_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_REVIEWS_GROUP_ID=-100xxxxxxxxxx
TELEGRAM_WEBHOOK_SECRET=случайная_строка_для_безопасности

# PALLY ПЛАТЕЖИ (pally.info)
PALLY_SHOP_ID=твой_shop_id
PALLY_SECRET_KEY=твой_secret_key
PALLY_WEBHOOK_SECRET=твой_webhook_secret
PALLY_API_URL=https://pally.info/api/v1
PALLY_TEST_MODE=true

# CRYPTOCLOUD — опционально, API остаётся в проекте; на витрине оплата через Pally / СБП / карту РФ
# CRYPTOCLOUD_API_KEY=
# CRYPTOCLOUD_SHOP_ID=

# ЯНДЕКС МЕТРИКА (metrika.yandex.ru)
NEXT_PUBLIC_YM_ID=12345678

# CRON: защита GET /api/cron/* (Vercel Cron)
CRON_SECRET=случайная_строка_для_крон_задач
# Задержка reminder по неоплаченному заказу (минуты, по умолчанию 60)
UNPAID_ORDER_REMINDER_DELAY_MINUTES=60
TELEGRAM_REVIEWS_CHAT=@digital_sub_reviews
NEXT_PUBLIC_TELEGRAM_REVIEWS_URL=https://t.me/digital_sub_reviews
