# ======================================================
# Supabase
# ======================================================

# URL проекта Supabase (из Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Публичный anon key Supabase (из Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role key (только на сервере, не NEXT_PUBLIC_!)
SUPABASE_SERVICE_ROLE_KEY=

# Subs Store (отдельный Supabase) — только для серверной админки GPT STORE при site=subs-store
SUBS_SUPABASE_URL=
SUBS_SUPABASE_SERVICE_ROLE_KEY=

# Subs Auth в браузере / middleware (anon — не секрет; обязательны для логина/сессии Subs Store в этом приложении)
NEXT_PUBLIC_SUBS_SUPABASE_URL=
NEXT_PUBLIC_SUBS_SUPABASE_ANON_KEY=

# ======================================================
# Домен приложения (без trailing slash)
# Production: твой Vercel / домен.
# Локально (один репозиторий, два dev-сервера):
#   npm run dev:subs  (или dev:sub) → http://127.0.0.1:3055/spotify
#   npm run dev:gpt   → http://127.0.0.1:3056/ и админка http://127.0.0.1:3056/admin?site=gpt-store|subs-store
# Порт занят: npm run dev:free-ports
# Опциональные алиасы (дублируют GPT-проект, если хотите явные имена):
# GPT_SUPABASE_URL=
# GPT_SUPABASE_ANON_KEY=
# GPT_SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3055
NEXT_PUBLIC_GPT_STORE_URL=http://127.0.0.1:3055
NEXT_PUBLIC_SPOTIFY_STORE_URL=http://127.0.0.1:3055/spotify
# Backward-compatible alias (optional, legacy name)
NEXT_PUBLIC_SUBS_STORE_URL=http://127.0.0.1:3055/spotify

# Общее приложение (редиректы, метаданные)
# NEXT_PUBLIC_APP_URL уже указан выше

# ======================================================
# Опционально: Resend для email (если не используется Supabase SMTP)
# ======================================================
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# ENABLE_RESEND_RESET_PASSWORD=1
